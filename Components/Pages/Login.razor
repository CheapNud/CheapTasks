@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]

<PageTitle>Sign in — CheapTasks</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="mt-16">
    <MudStack Spacing="6" AlignItems="AlignItems.Stretch">

        <MudStack Spacing="2" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Rounded.TaskAlt"
                     Color="Color.Primary"
                     Style="font-size: 3.5rem;" />
            <MudText Typo="Typo.h3" Align="Align.Center">CheapTasks</MudText>
            <MudText Typo="Typo.body2" Align="Align.Center"
                     Style="color: var(--mud-palette-text-secondary);">
                Just another tasks/todo app.
            </MudText>
        </MudStack>

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="true">
                @_error
            </MudAlert>
        }

        <MudPaper Elevation="3" Class="pa-6">
            <MudStack Spacing="3">
                <MudButton Href="/auth/plex-start"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Rounded.Login">
                    Sign in with Plex
                </MudButton>

                <MudText Typo="Typo.caption" Align="Align.Center"
                         Style="color: var(--mud-palette-text-secondary);">
                    Access is limited to members of the Plex server.
                </MudText>
            </MudStack>
        </MudPaper>
    </MudStack>
</MudContainer>

@code {
    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    private string? _error;

    protected override void OnParametersSet()
    {
        _error = Error;
    }
}

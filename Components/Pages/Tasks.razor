@page "/"
@page "/tasks"
@attribute [Authorize]
@inject TaskRepo TaskRepo
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>CheapTasks</PageTitle>

<MudStack Spacing="4">

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.h4">My tasks</MudText>
        @if (_tasks.Count > 0)
        {
            <MudStack Row="true" Spacing="1">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">
                    @ActiveCount active
                </MudChip>
                @if (DoneCount > 0)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">
                        @DoneCount done
                    </MudChip>
                }
            </MudStack>
        }
    </MudStack>

    <MudPaper Elevation="2" Class="py-2 px-1">
        <MudTextField @bind-Value="_newTitle"
                      Placeholder="What needs doing?"
                      Variant="Variant.Text"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Rounded.AddCircle"
                      AdornmentColor="@AddIconColor"
                      OnAdornmentClick="AddTask"
                      OnKeyDown="OnNewTitleKey"
                      Immediate="true"
                      Disabled="_busy"
                      Class="px-3" />
    </MudPaper>

    @if (_tasks.Count > 0)
    {
        <MudTabs ActivePanelIndex="@_filterIndex"
                 ActivePanelIndexChanged="OnFilterChange"
                 Color="Color.Primary"
                 Rounded="true"
                 Border="false"
                 Outlined="false">
            <MudTabPanel Text="@($"Active ({ActiveCount})")" />
            <MudTabPanel Text="@($"Done ({DoneCount})")" />
            <MudTabPanel Text="@($"All ({_tasks.Count})")" />
        </MudTabs>
    }

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_filteredTasks.Count == 0)
    {
        <MudPaper Outlined="true" Elevation="0" Class="pa-10 d-flex flex-column align-center">
            <MudIcon Icon="@EmptyIcon" Size="Size.Large"
                     Style="color: var(--mud-palette-text-disabled); font-size: 3rem;" />
            <MudText Typo="Typo.body1" Class="mt-3"
                     Style="color: var(--mud-palette-text-secondary);">
                @EmptyMessage
            </MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="1">
            @for (var i = 0; i < _filteredTasks.Count; i++)
            {
                var task = _filteredTasks[i];
                var isLast = i == _filteredTasks.Count - 1;

                <div class="task-row d-flex align-center gap-3 px-3 py-2"
                     style="@(isLast ? "" : "border-bottom: 1px solid var(--mud-palette-divider);")">
                    <MudCheckBox T="bool" Value="task.Done"
                                 ValueChanged="@(done => ToggleDone(task, done))"
                                 Color="Color.Primary" Dense="true" />

                    <div class="flex-grow-1" style="min-width: 0;">
                        <MudText Typo="Typo.body1"
                                 Style="@(task.Done
                                     ? "text-decoration: line-through; color: var(--mud-palette-text-disabled);"
                                     : "")">
                            @task.Title
                        </MudText>
                        @if (!string.IsNullOrWhiteSpace(task.Notes))
                        {
                            <MudText Typo="Typo.caption"
                                     Style="color: var(--mud-palette-text-secondary);">
                                @task.Notes
                            </MudText>
                        }
                    </div>

                    @if (task.DueUtc.HasValue)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                 Color="@(task.DueUtc.Value < DateTime.UtcNow && !task.Done ? Color.Warning : Color.Default)"
                                 Icon="@Icons.Material.Outlined.Schedule">
                            @task.DueUtc.Value.ToLocalTime().ToString("MMM d")
                        </MudChip>
                    }

                    <MudTooltip Text="Edit">
                        <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                       Size="Size.Small"
                                       Style="color: var(--mud-palette-text-disabled);"
                                       OnClick="@(() => EditTask(task))" />
                    </MudTooltip>
                    <MudTooltip Text="Delete">
                        <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                       Size="Size.Small"
                                       Style="color: var(--mud-palette-text-disabled);"
                                       OnClick="@(() => DeleteTask(task))" />
                    </MudTooltip>
                </div>
            }
        </MudPaper>
    }
</MudStack>

<style>
    .task-row {
        transition: background-color 120ms ease;
    }
    .task-row:hover {
        background-color: var(--mud-palette-action-default-hover);
    }
</style>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private enum TaskFilter { Active = 0, Done = 1, All = 2 }

    private List<TaskItem> _tasks = [];
    private string _newTitle = string.Empty;
    private bool _loading = true;
    private bool _busy;
    private string? _ownerId;
    private int _filterIndex;

    private TaskFilter Filter => (TaskFilter)_filterIndex;

    private int ActiveCount => _tasks.Count(t => !t.Done);
    private int DoneCount => _tasks.Count(t => t.Done);

    private Color AddIconColor =>
        string.IsNullOrWhiteSpace(_newTitle) ? Color.Default : Color.Primary;

    private List<TaskItem> _filteredTasks => Filter switch
    {
        TaskFilter.Active => _tasks.Where(t => !t.Done).ToList(),
        TaskFilter.Done => _tasks.Where(t => t.Done).ToList(),
        _ => _tasks
    };

    private string EmptyIcon => Filter switch
    {
        TaskFilter.Done => Icons.Material.Outlined.RadioButtonUnchecked,
        _ => Icons.Material.Outlined.Inbox
    };

    private string EmptyMessage => Filter switch
    {
        TaskFilter.Active when _tasks.Count > 0 => "All caught up.",
        TaskFilter.Done => "Nothing completed yet.",
        _ => "Add your first task above."
    };

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null) return;
        var state = await AuthState;
        _ownerId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        await Reload();
    }

    private async Task Reload()
    {
        if (_ownerId is null) return;
        _loading = true;
        _tasks = await TaskRepo.GetForOwnerAsync(_ownerId);
        _loading = false;
    }

    private void OnFilterChange(int index)
    {
        _filterIndex = index;
    }

    private async Task OnNewTitleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_newTitle))
            await AddTask();
    }

    private async Task AddTask()
    {
        if (_ownerId is null || string.IsNullOrWhiteSpace(_newTitle)) return;

        _busy = true;
        try
        {
            var task = new TaskItem
            {
                OwnerId = _ownerId,
                Title = _newTitle.Trim(),
            };
            await TaskRepo.AddAsync(task);
            _newTitle = string.Empty;
            await Reload();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ToggleDone(TaskItem task, bool done)
    {
        if (_ownerId is null) return;
        await TaskRepo.SetDoneAsync(task.Id, _ownerId, done);
        task.Done = done;
        task.CompletedUtc = done ? DateTime.UtcNow : null;
    }

    private async Task DeleteTask(TaskItem task)
    {
        if (_ownerId is null) return;
        await TaskRepo.DeleteAsync(task.Id, _ownerId);
        Snackbar.Add($"Deleted \"{task.Title}\"", Severity.Info);
        _tasks.Remove(task);
    }

    private async Task EditTask(TaskItem task)
    {
        var parameters = new DialogParameters<EditTaskDialog>
        {
            { x => x.Task, task }
        };
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            BackdropClick = false,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
        };

        var dialog = await DialogService.ShowAsync<EditTaskDialog>("Edit task", parameters, options);
        await dialog.Result;
    }
}

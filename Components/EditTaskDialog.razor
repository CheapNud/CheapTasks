@using System.Diagnostics
@inject TaskRepo TaskRepo
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Rounded.Edit" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Edit task</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Class="pt-2" Style="min-width: 320px;">
            <MudTextField @bind-Value="_title"
                          Label="Title"
                          Variant="Variant.Outlined"
                          Required="true"
                          Immediate="true"
                          MaxLength="200"
                          AutoFocus="true" />
            <MudTextField @bind-Value="_notes"
                          Label="Notes"
                          Variant="Variant.Outlined"
                          Lines="3"
                          MaxLength="2000"
                          HelperText="Optional details" />
            <MudAutocomplete T="string"
                             @bind-Value="_location"
                             Label="Room / location"
                             Variant="Variant.Outlined"
                             SearchFunc="SearchLocations"
                             CoerceValue="true"
                             CoerceText="false"
                             ResetValueOnEmptyText="true"
                             Clearable="true"
                             MaxLength="60"
                             HelperText="Optional — type a new one or pick from existing" />
            <MudDatePicker @bind-Date="_dueDate"
                           Label="Due date"
                           Variant="Variant.Outlined"
                           Clearable="true"
                           HelperText="Optional" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="_busy">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Save"
                   Disabled="@(_busy || string.IsNullOrWhiteSpace(_title))">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter, EditorRequired]
    public TaskItem Item { get; set; } = default!;

    [Parameter]
    public IReadOnlyList<string> KnownLocations { get; set; } = [];

    private string _title = string.Empty;
    private string? _notes;
    private string? _location;
    private DateTime? _dueDate;
    private bool _busy;

    protected override void OnInitialized()
    {
        _title = Item.Title;
        _notes = Item.Notes;
        _location = Item.Location;
        _dueDate = Item.DueUtc?.ToLocalTime();
    }

    private async Task<IEnumerable<string>> SearchLocations(string value, CancellationToken ct)
    {
        await Task.CompletedTask;
        if (KnownLocations.Count == 0) return [];
        if (string.IsNullOrWhiteSpace(value)) return KnownLocations;
        return KnownLocations.Where(l => l.Contains(value, StringComparison.OrdinalIgnoreCase));
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_title)) return;

        var originalTitle = Item.Title;
        var originalNotes = Item.Notes;
        var originalLocation = Item.Location;
        var originalDueUtc = Item.DueUtc;

        _busy = true;
        try
        {
            Item.Title = _title.Trim();
            Item.Notes = string.IsNullOrWhiteSpace(_notes) ? null : _notes.Trim();
            Item.Location = string.IsNullOrWhiteSpace(_location) ? null : _location.Trim();
            Item.DueUtc = _dueDate.HasValue
                ? DateTime.SpecifyKind(_dueDate.Value, DateTimeKind.Local).ToUniversalTime()
                : null;

            await TaskRepo.UpdateAsync(Item);
            Snackbar.Add($"Saved \"{Item.Title}\"", Severity.Success);
            MudDialog.Close(DialogResult.Ok(Item));
        }
        catch (Exception ex)
        {
            Item.Title = originalTitle;
            Item.Notes = originalNotes;
            Item.Location = originalLocation;
            Item.DueUtc = originalDueUtc;
            Debug.WriteLine($"EditTaskDialog.Save failed: {ex}");
            Snackbar.Add("Could not save changes. Please try again.", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}

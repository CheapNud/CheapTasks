@using System.Diagnostics
@inject TaskRepo TaskRepo
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Rounded.Edit" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Edit task</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Class="pt-2" Style="min-width: 320px;">
            <MudSwitch T="bool"
                       Value="@(_kind == TaskKind.Decision)"
                       ValueChanged="OnKindToggle"
                       Label="Treat as a decision / research item"
                       Color="Color.Primary" />
            <MudTextField @bind-Value="_title"
                          Label="@(_kind == TaskKind.Decision ? "Question" : "Title")"
                          Variant="Variant.Outlined"
                          Required="true"
                          Immediate="true"
                          MaxLength="200"
                          AutoFocus="true" />
            @if (_kind == TaskKind.Decision)
            {
                <MudTextField @bind-Value="_options"
                              Label="Options"
                              Variant="Variant.Outlined"
                              Lines="4"
                              MaxLength="1000"
                              HelperText="One per line" />
            }
            <MudTextField @bind-Value="_notes"
                          Label="Notes"
                          Variant="Variant.Outlined"
                          Lines="3"
                          MaxLength="2000"
                          HelperText="Optional details" />
            <MudDatePicker @bind-Date="_dueDate"
                           Label="Due date"
                           Variant="Variant.Outlined"
                           Clearable="true"
                           HelperText="Optional" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="_busy">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Save"
                   Disabled="@(_busy || string.IsNullOrWhiteSpace(_title))">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter, EditorRequired]
    public TaskItem Task { get; set; } = default!;

    private string _title = string.Empty;
    private string? _notes;
    private string? _options;
    private TaskKind _kind;
    private DateTime? _dueDate;
    private bool _busy;

    protected override void OnInitialized()
    {
        _title = Task.Title;
        _notes = Task.Notes;
        _options = Task.Options;
        _kind = Task.Kind;
        _dueDate = Task.DueUtc?.ToLocalTime();
    }

    private void OnKindToggle(bool isDecision)
    {
        _kind = isDecision ? TaskKind.Decision : TaskKind.Todo;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_title)) return;

        var originalTitle = Task.Title;
        var originalNotes = Task.Notes;
        var originalOptions = Task.Options;
        var originalKind = Task.Kind;
        var originalDueUtc = Task.DueUtc;

        _busy = true;
        try
        {
            Task.Title = _title.Trim();
            Task.Notes = string.IsNullOrWhiteSpace(_notes) ? null : _notes.Trim();
            Task.Kind = _kind;
            Task.Options = _kind == TaskKind.Decision && !string.IsNullOrWhiteSpace(_options)
                ? _options.Trim()
                : null;
            Task.DueUtc = _dueDate.HasValue
                ? DateTime.SpecifyKind(_dueDate.Value, DateTimeKind.Local).ToUniversalTime()
                : null;

            await TaskRepo.UpdateAsync(Task);
            Snackbar.Add($"Saved \"{Task.Title}\"", Severity.Success);
            MudDialog.Close(DialogResult.Ok(Task));
        }
        catch (Exception ex)
        {
            Task.Title = originalTitle;
            Task.Notes = originalNotes;
            Task.Options = originalOptions;
            Task.Kind = originalKind;
            Task.DueUtc = originalDueUtc;
            Debug.WriteLine($"EditTaskDialog.Save failed: {ex}");
            Snackbar.Add("Could not save changes. Please try again.", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
